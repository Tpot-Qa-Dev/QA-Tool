# ─────────────────────────────────────────────────────────────
#  QA Tool Backend — Environment Variables
#  Copy → rename to .env → fill in your keys
#  NEVER commit .env to git
# ─────────────────────────────────────────────────────────────

# ── REQUIRED (pick one) ───────────────────────────────────────
# OpenRouter API Key — recommended; one key unlocks many models via OpenRouter.
# Get: https://openrouter.ai/keys
# Format: sk-or-v1-...
OPENROUTER_API_KEY=

# Optional default model when using OPENROUTER_API_KEY (provider-prefixed slug).
# OPENROUTER_MODEL=anthropic/claude-3.5-sonnet

# Anthropic Claude API Key — optional fallback if you prefer direct Anthropic access.
# Get: https://console.anthropic.com → API Keys → Create Key
# Format: sk-ant-api03-...
# CLAUDE_API_KEY=

# ── OPTIONAL (but recommended) ────────────────────────────────
# Google PageSpeed Insights API Key
# Get free key: https://developers.google.com/speed/docs/insights/v5/get-started
# Free tier: 25,000 requests/day — works without key at lower rate
PSI_API_KEY=

# Figma Personal Access Token
# Get: Figma → Profile → Settings → Access tokens → Generate new token
# Only needed for the Figma vs Web module
FIGMA_TOKEN=

# ── SERVER CONFIG ─────────────────────────────────────────────
PORT=3001
FRONTEND_URL=http://localhost:5173

# ── PLAYWRIGHT ────────────────────────────────────────────────
# Browser mode. Leave unset (or "true") for headless.
# Set HEADLESS=false to watch Chromium run in a visible window — useful
# for debugging audits. Slower and requires a desktop session.
HEADLESS=true
